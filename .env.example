# HuggingFace offline mode (prevent network access)
HF_HUB_OFFLINE=1
HF_HUB_CACHE=D:/huggingface_data/hub

# Database (port 5432 — PostgreSQL default port)
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5432/nexusrag

# ChromaDB (port 8002)
CHROMA_HOST=localhost
CHROMA_PORT=8002

# 禁用 huggingface symlinks
HF_HUB_DISABLE_SYMLINKS=true

# ===========================================
# LLM Provider: "gemini" | "ollama"
# Chuyển provider: comment block này, uncomment block kia
# ===========================================
# 启用 OpenAI Provider
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.chatanywhere.tech/v1
OPENAI_MODEL=gpt-4o-mini  # 或 gpt-4-turbo, gpt-4o-mini

# Thinking level for Gemini 3.x+: "minimal" | "low" | "medium" | "high"
# Gemini 2.5 uses thinking_budget_tokens automatically (this setting is ignored)
LLM_THINKING_LEVEL=medium

# Max output tokens for chat (includes thinking tokens)
# Gemini 2.5 Flash: up to 8192, Gemini 3.1 Flash-Lite: up to 65536
LLM_MAX_OUTPUT_TOKENS=8192

# --- Ollama (inactive — uncomment để dùng, comment Gemini ở trên) ---
# LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# Multimodal (Recommend)
# OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_MODEL=qwen3.5:4b
# OLLAMA_MODEL=gemma3:12b
# Text only model
# OLLAMA_MODEL=kamekichi128/qwen3-4b-instruct-2507
# Enable thinking mode for Ollama (default: false — reduces latency for thinking models like qwen3.5)
# OLLAMA_ENABLE_THINKING=false

# ===========================================
# KG Embedding (có thể khác LLM provider)
# ===========================================

# --- KG Embedding: Gemini (active) ---
# KG_EMBEDDING_PROVIDER=gemini
# KG_EMBEDDING_MODEL=gemini-embedding-001
# KG_EMBEDDING_DIMENSION=3072

# --- KG Embedding: Ollama (inactive) ---
# KG_EMBEDDING_PROVIDER=ollama
# KG_EMBEDDING_MODEL=bge-m3
# KG_EMBEDDING_DIMENSION=1024

# --- KG Embedding: Sentence-Transformers (inactive — fully local, no API needed) ---
# KG_EMBEDDING_PROVIDER=sentence_transformers
# KG_EMBEDDING_MODEL=BAAI/bge-m3
# KG_EMBEDDING_DIMENSION=1024

# --- KG Embedding: OpenAI (active) ---
KG_EMBEDDING_PROVIDER=openai
KG_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Independent OpenAI config for KG embeddings
# If not set, falls back to global OPENAI_* configs
# KG_OPENAI_API_KEY=sk-xxx
# KG_OPENAI_BASE_URL=https://api.openai.com/v1
# KG_OPENAI_ORGANIZATION=org-xxx

# NexusRAG Pipeline (all optional, defaults shown)
NEXUSRAG_ENABLED=true
NEXUSRAG_ENABLE_KG=true
NEXUSRAG_KG_LANGUAGE=Chinese
NEXUSRAG_KG_ENTITY_TYPES=["Model","Dataset","Method","Task","Metric","Framework","Architecture","Layer","Optimizer","Loss","Organization","Person","Publication","Year","Hardware","Hyperparameter","Code","Technology"]
NEXUSRAG_ENABLE_IMAGE_EXTRACTION=true
NEXUSRAG_ENABLE_IMAGE_CAPTIONING=false
NEXUSRAG_ENABLE_TABLE_CAPTIONING=false
NEXUSRAG_ENABLE_FORMULA_ENRICHMENT=true

# Docling accelerator: "auto" (detect GPU automatically), "cpu", "cuda"
# Set to "cuda" or "auto" to use GPU acceleration
NEXUSRAG_DOCLING_DEVICE=auto
NEXUSRAG_DOCLING_NUM_THREADS=4

CHROMA_EMBEDDING_PROVIDER=openai

# ChromaDB OpenAI embedding independent config (optional - fallback to OPENAI_* if not set)
# CHROMA_OPENAI_API_KEY=sk-xxx
# CHROMA_OPENAI_BASE_URL=https://api.openai.com/v1
# CHROMA_OPENAI_ORGANIZATION=org-xxx

CHROMA_OPENAI_MODEL=text-embedding-3-small

# ===========================================
# KG Embedding Independent Config (for KG_EMBEDDING_PROVIDER=openai)
# These override the global OPENAI_* configs when set
# ===========================================
# KG_OPENAI_API_KEY=sk-xxx
# KG_OPENAI_BASE_URL=https://api.openai.com/v1
# KG_OPENAI_ORGANIZATION=org-xxx

# Reranker Provider (using Gitee AI cloud service)
RERANKER_PROVIDER=gitee_ai
GITEE_AI_API_TOKEN=xxx
GITEE_AI_RERANK_MODEL=bge-reranker-v2-m3
GITEE_AI_RERANK_TOP_N=10

NEXUSRAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
NEXUSRAG_CHUNK_MAX_TOKENS=512
NEXUSRAG_VECTOR_PREFETCH=20
NEXUSRAG_RERANKER_TOP_K=8
NEXUSRAG_MIN_RELEVANCE_SCORE=0.15

# CORS
CORS_ORIGINS=["http://localhost:5174","http://localhost:3000"]

# Database (port 5433 — tách biệt khỏi SlideAgentPro)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/nexusrag

# ChromaDB (port 8002 — tách biệt khỏi SlideAgentPro)
CHROMA_HOST=localhost
CHROMA_PORT=8002

# ===========================================
# LLM Provider: "gemini" | "openai" | "ollama"
# Switch provider: comment this block, uncomment the other
# ===========================================

# --- OpenAI / OpenAI-compatible (active) ---
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key
# Base URL (OpenAI: https://api.openai.com/v1)
# For other providers (OpenRouter, Azure, LocalAI, vLLM): set their endpoint
OPENAI_BASE_URL=https://api.openai.com/v1
# OpenAI model (gpt-4o, gpt-4-turbo, gpt-4o-mini, etc.)
OPENAI_MODEL=gpt-4o

# --- Gemini (inactive — uncomment to use, comment OpenAI above) ---
# LLM_PROVIDER=gemini
# GOOGLE_AI_API_KEY=your-gemini-api-key
# LLM_MODEL_FAST=gemini-2.5-flash
# LLM_THINKING_LEVEL=medium
# LLM_MAX_OUTPUT_TOKENS=8192

# --- Ollama (inactive — uncomment to use, comment others above) ---
# LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
# Multimodal models (qwen3.5:9b, gemma3:12b)
# OLLAMA_MODEL=gemma3:12b
# Enable thinking mode for Ollama (default: false)
# OLLAMA_ENABLE_THINKING=false

# ===========================================
# KG Embedding (can differ from LLM provider)
# ===========================================

# --- KG Embedding: OpenAI (active) ---
KG_EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536

# --- KG Embedding: Gemini (inactive) ---
# KG_EMBEDDING_PROVIDER=gemini
# KG_EMBEDDING_MODEL=gemini-embedding-001
# KG_EMBEDDING_DIMENSION=3072

# --- KG Embedding: Ollama (inactive) ---
# KG_EMBEDDING_PROVIDER=ollama
# KG_EMBEDDING_MODEL=bge-m3
# KG_EMBEDDING_DIMENSION=1024

# --- KG Embedding: Sentence-Transformers (inactive — fully local, no API needed) ---
# KG_EMBEDDING_PROVIDER=sentence_transformers
# KG_EMBEDDING_MODEL=BAAI/bge-m3
# KG_EMBEDDING_DIMENSION=1024

# ===========================================
# ChromaDB Embedding Provider (for vector search)
# Can use same provider as KG or different
# ===========================================

# --- ChromaDB Embedding: OpenAI (active) ---
# CHROMA_EMBEDDING_PROVIDER=openai
# CHROMA_OPENAI_MODEL=text-embedding-3-small
# CHROMA_OPENAI_DIMENSION=1536
# Reuses OPENAI_API_KEY, OPENAI_BASE_URL from above

# --- ChromaDB Embedding: Gemini (inactive) ---
# CHROMA_EMBEDDING_PROVIDER=gemini
# CHROMA_GEMINI_MODEL=gemini-embedding-001
# CHROMA_GEMINI_DIMENSION=3072
# Reuses GOOGLE_AI_API_KEY

# --- ChromaDB Embedding: Ollama (inactive) ---
# CHROMA_EMBEDDING_PROVIDER=ollama
# CHROMA_OLLAMA_MODEL=nomic-embed-text
# CHROMA_OLLAMA_DIMENSION=768
# Reuses OLLAMA_HOST

# --- ChromaDB Embedding: Sentence-Transformers (inactive — local) ---
# CHROMA_EMBEDDING_PROVIDER=sentence_transformers
# NEXUSRAG_EMBEDDING_MODEL=BAAI/bge-m3  # used only for this provider

# ===========================================
# Reranker Provider (for cross-encoder reranking)
# ===========================================

# --- Reranker: Sentence-Transformers (active - local) ---
# RERANKER_PROVIDER=sentence_transformers
# NEXUSRAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# --- Reranker: Cohere API (inactive) ---
# RERANKER_PROVIDER=cohere
# COHERE_API_KEY=your-cohere-api-key
# COHERE_RERANK_MODEL=rerank-english-v3.0
# COHERE_RERANK_TOP_N=10

# --- Reranker: Jina AI API (inactive) ---
# RERANKER_PROVIDER=jina
# JINA_API_KEY=your-jina-api-key
# JINA_RERANK_MODEL=jina-reranker-v2-multilingual
# JINA_RERANK_TOP_N=10

# --- Reranker: ModelScope API (inactive) ---
# NOTE: ModelScope inference API has WAF protection that blocks direct HTTP calls.
#       Use the ModelScope Python SDK instead:
#         pip install modelscope
#         from modelscope import pipeline
#         reranker = pipeline(Tasks.text_reranking, model="BAAI/bge-reranker-v2-m3")
#       Or use sentence_transformers (local, no API needed) — recommended.
# RERANKER_PROVIDER=modelscope
# MODELSCOPE_API_KEY=your-modelscope-api-key
# MODELSCOPE_BASE_URL=https://ms-ens-6f01371a-0c58.api-inference.modelscope.cn/v1
# MODELSCOPE_RERANK_MODEL=BAAI/bge-reranker-v2-m3
# MODELSCOPE_RERANK_TOP_N=10

# NexusRAG Pipeline (all optional, defaults shown)
NEXUSRAG_ENABLED=true
NEXUSRAG_ENABLE_KG=true
NEXUSRAG_KG_LANGUAGE=Vietnamese
NEXUSRAG_KG_ENTITY_TYPES=["Organization","Person","Product","Location","Event","Financial_Metric","Technology","Date","Regulation"]
NEXUSRAG_ENABLE_IMAGE_EXTRACTION=true
NEXUSRAG_ENABLE_IMAGE_CAPTIONING=true
NEXUSRAG_EMBEDDING_MODEL=BAAI/bge-m3
NEXUSRAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
NEXUSRAG_CHUNK_MAX_TOKENS=512
NEXUSRAG_VECTOR_PREFETCH=20
NEXUSRAG_RERANKER_TOP_K=8
NEXUSRAG_MIN_RELEVANCE_SCORE=0.15

# CORS
CORS_ORIGINS=["http://localhost:5174","http://localhost:3000"]
